# Backend runtime mode: development keeps the local HTTP defaults; production requires HTTPS URLs and a real secret.
NODE_ENV=development
# Backend bind address and port. Production hosting commonly uses 0.0.0.0.
HOST=
PORT=
# PostgreSQL connection string.
DATABASE_URL=
# Better Auth public backend URL and session signing secret (at least 32 random characters).
BETTER_AUTH_URL=
BETTER_AUTH_SECRET=
# Frontend origin allowed by CORS and Better Auth.
FRONTEND_URL=
# Cookie settings. Use "none" only when the frontend and backend are cross-site; HTTPS is required for that mode.
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
# External provider credentials.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
OMDB_API_KEY=

# Frontend build/runtime values.
# API URL should include the backend API prefix, for example https://api.example.com/api/v1.
VITE_API_URL=
# Optional separate Better Auth origin; otherwise the origin of VITE_API_URL is used.
VITE_AUTH_URL=
# Development-only Vite proxy target; defaults to http://localhost:3000.
VITE_DEV_API_PROXY=
